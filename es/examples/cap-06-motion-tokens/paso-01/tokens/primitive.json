{
  "motion": {
    "duration": {
      "instant": { "$value": "0ms",   "$type": "duration", "$description": "Para casos donde animar no aporta." },
      "fast":    { "$value": "150ms", "$type": "duration", "$description": "Hover, focus, microinteracciones." },
      "normal":  { "$value": "250ms", "$type": "duration", "$description": "Default. Modales, drawers." },
      "slow":    { "$value": "400ms", "$type": "duration", "$description": "Cambios de contexto grandes." },
      "slower":  { "$value": "600ms", "$type": "duration", "$description": "Maximo, usar con criterio." }
    },
    "ease": {
      "out":         { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier", "$description": "El defecto. Si solo recuerdas uno, este." },
      "in":          { "$value": "cubic-bezier(0.7, 0, 0.84, 0)", "$type": "cubicBezier" },
      "in-out":      { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" },
      "emphasized":  { "$value": "cubic-bezier(0.2, 0, 0, 1)",     "$type": "cubicBezier", "$description": "Para destacar exito o confirmacion." }
    },
    "stagger": {
      "fast":   { "$value": "30ms", "$type": "duration" },
      "normal": { "$value": "50ms", "$type": "duration" },
      "slow":   { "$value": "80ms", "$type": "duration" }
    }
  }
}
